generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STORE_MANAGER
  CASHIER
}

enum Plan {
  FREE
  PRO
}

enum PaymentMethod {
  CASH
  MTN_MOMO
  AIRTEL_MONEY
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum StockEntryType {
  IN
  OUT
  TRANSFER
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  LOW_STOCK
  NEW_REPORT
  TRANSFER_REQUEST
  NEW_MESSAGE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VOID
  APPROVE
  REJECT
}

// ─── Better Auth required tables ────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  passwordHash  String?
  role          Role     @default(CASHIER)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  organisationId String?
  branchId       String?

  organisation Organisation? @relation(fields: [organisationId], references: [id])
  branch       Branch?       @relation(fields: [branchId], references: [id])

  sessions Session[]
  accounts Account[]

  sales        Sale[]
  stockEntries StockEntry[]
  dailyReports DailyReport[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  notifications    Notification[]
  auditLogs        AuditLog[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ─── Tenant models ───────────────────────────────────────────────────────────

model Organisation {
  id                String   @id @default(cuid())
  name              String
  logoUrl           String?
  plan              Plan     @default(FREE)
  lowStockThreshold Int      @default(10)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  branches      Branch[]
  users         User[]
  categories    Category[]
  products      Product[]
  suppliers     Supplier[]
  stockEntries  StockEntry[]
  sales         Sale[]
  dailyReports  DailyReport[]
  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("organisation")
}

model Branch {
  id             String   @id @default(cuid())
  name           String
  location       String?
  phone          String?
  organisationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  users        User[]

  stockEntries StockEntry[] @relation("BranchStockEntries")
  transfersIn  StockEntry[] @relation("TransferTo")
  sales                Sale[]
  dailyReports         DailyReport[]
  productBranchStocks  ProductBranchStock[]

  @@map("branch")
}

// ─── Inventory models ────────────────────────────────────────────────────────

model Category {
  id             String   @id @default(cuid())
  name           String
  organisationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([name, organisationId])
  @@map("category")
}

model Product {
  id             String   @id @default(cuid())
  name           String
  sku            String?
  description    String?
  imageUrl       String?
  price          Decimal  @db.Decimal(12, 2)
  costPrice      Decimal? @db.Decimal(12, 2)
  unit           String   @default("pcs")
  categoryId     String
  organisationId String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category     Category     @relation(fields: [categoryId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  branchStocks ProductBranchStock[]
  stockEntries StockEntry[]
  saleItems    SaleItem[]

  @@map("product")
}

// Per-branch stock level for each product
model ProductBranchStock {
  id        String   @id @default(cuid())
  productId String
  branchId  String
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([productId, branchId])
  @@map("product_branch_stock")
}

model Supplier {
  id             String   @id @default(cuid())
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  organisationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  stockEntries StockEntry[]

  @@map("supplier")
}

model StockEntry {
  id             String         @id @default(cuid())
  type           StockEntryType
  quantity       Int
  notes          String?
  organisationId String
  branchId       String
  productId      String
  supplierId     String?
  userId         String
  transferStatus TransferStatus?
  toBranchId     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation("BranchStockEntries", fields: [branchId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  supplier     Supplier?    @relation(fields: [supplierId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  toBranch     Branch?      @relation("TransferTo", fields: [toBranchId], references: [id])

  @@map("stock_entry")
}

// ─── Sales models ─────────────────────────────────────────────────────────────

model Sale {
  id             String        @id @default(cuid())
  organisationId String
  branchId       String
  cashierId      String
  paymentMethod  PaymentMethod @default(CASH)
  status         SaleStatus    @default(COMPLETED)
  subtotal       Decimal       @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id])
  cashier      User         @relation(fields: [cashierId], references: [id])

  items SaleItem[]

  @@map("sale")
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_item")
}

// ─── Operations models ───────────────────────────────────────────────────────

model DailyReport {
  id             String   @id @default(cuid())
  organisationId String
  branchId       String
  cashierId      String
  date           DateTime @db.Date
  totalSales     Decimal  @db.Decimal(12, 2)
  cashAmount     Decimal  @db.Decimal(12, 2)
  momoAmount     Decimal  @db.Decimal(12, 2)
  salesCount     Int
  notes          String?
  isReviewed     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  branch       Branch       @relation(fields: [branchId], references: [id])
  cashier      User         @relation(fields: [cashierId], references: [id])

  @@unique([branchId, cashierId, date])
  @@map("daily_report")
}

model Message {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  subject     String
  body        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sender    User @relation("SentMessages", fields: [senderId], references: [id])
  recipient User @relation("ReceivedMessages", fields: [recipientId], references: [id])

  @@map("message")
}

model Notification {
  id             String           @id @default(cuid())
  organisationId String
  userId         String
  type           NotificationType
  title          String
  body           String
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification")
}

model AuditLog {
  id             String      @id @default(cuid())
  organisationId String
  userId         String
  action         AuditAction
  entity         String
  entityId       String
  details        Json?
  createdAt      DateTime    @default(now())

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@map("audit_log")
}
